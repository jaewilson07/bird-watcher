    "\n",
    "Overwrite `src/bird_watcher/web.py` with this version so it's used at runtime."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "save-code",
   "metadata": {},
   "outputs": [],
   "source": [
